{
	"name": "meow-db",
	"version": "0.0.0",
	"license": "MIT",
	"bin": {
		"meowdb": "dist/bundle.js"
	},
	"type": "module",
	"scripts": {
		"build": "rm -rf dist && tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/bundle.js",
		"local": "npm run build && npm link",
		"test": "npm run build && node --test test/**/*.test.mjs"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"ink": "^4.1.0",
		"meow": "^11.0.0",
		"pg": "^8.20.0",
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"esbuild": "^0.27.4",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"typescript": "^5.9.3",
		"xo": "^0.53.1"
	}
}
