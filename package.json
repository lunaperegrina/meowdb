{
	"name": "@lunaperegrina/meowdb",
	"version": "0.0.3",
	"license": "MIT",
	"bin": {
		"meowdb": "dist/bundle.js"
	},
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "rm -rf dist && tsc --noEmit && esbuild src/index.tsx --bundle --minify --platform=node --format=esm --packages=external --outfile=dist/bundle.js",
		"local": "npm run build && npm link",
		"dev": "bun --hot src/index.tsx"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"ink": "^6.8.0",
		"pg": "^8.20.0",
		"react": "^19.2.4"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"@types/react": "^19.2.14",
		"esbuild": "^0.27.4",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	}
}
